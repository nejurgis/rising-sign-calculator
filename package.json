{
  "name": "rising-sign-calculator",
  "version": "1.0.0",
  "description": "Astrological Rising Sign Calculator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "esbuild src/app.js --bundle=false --minify --outfile=public/app.js && esbuild src/style.css --minify --outfile=public/style.css",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "wrangler": "^4.93.0"
  }
}
